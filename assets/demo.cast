[7.325, "o", "\u001b[2m\u25cf Reading the file and checking for common patterns\u2026\u001b[0m\r\n"]
[7.725, "o", "\u001b[33m[Read]\u001b[0m src/api.py \u001b[2m(142 lines)\u001b[0m\r\n"]
[8.225, "o", "  \u001b[2m43:  query = f\"SELECT * FROM users WHERE name = '{name}'\"\u001b[0m\r\n"]
[8.425, "o", "  \u001b[2m78:  @app.post('/login')\u001b[0m\r\n"]
[8.625, "o", "  \u001b[2m96:  return redirect(request.args['next'])\u001b[0m\r\n"]
[9.125, "o", "\u001b[33m[Grep]\u001b[0m 'execute|cursor' src/ \u001b[2m(3 matches)\u001b[0m\r\n\r\n"]
[9.725, "o", "\u001b[1mFound 3 issues:\u001b[0m\r\n\r\n"]
[10.225, "o", "\u001b[31m1.\u001b[0m \u001b[1mSQL injection\u001b[0m \u001b[90m\u2014 line 43\u001b[0m\r\n"]
[10.475, "o", "   f-string interpolation lets a crafted ?name= leak the whole table.\r\n   \u001b[32mfix:\u001b[0m use a parameterised query \u2014 \u001b[36mcursor.execute(sql, (name,))\u001b[0m\r\n\r\n"]
[10.975, "o", "\u001b[31m2.\u001b[0m \u001b[1mNo rate limiting on /login\u001b[0m \u001b[90m\u2014 line 78\u001b[0m\r\n"]
[11.225, "o", "   no slowapi/flask-limiter; brute-force is trivial.\r\n   \u001b[32mfix:\u001b[0m add \u001b[36m@limiter.limit('5/minute')\u001b[0m or move to fail2ban\r\n\r\n"]
[11.725, "o", "\u001b[31m3.\u001b[0m \u001b[1mOpen redirect\u001b[0m \u001b[90m\u2014 line 96\u001b[0m\r\n"]
[11.975, "o", "   ?next= is taken verbatim \u2014 phishing payload.\r\n   \u001b[32mfix:\u001b[0m validate scheme+host against an allowlist before redirect\r\n\r\n"]
